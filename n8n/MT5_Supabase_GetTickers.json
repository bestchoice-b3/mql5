            }
          ]
        },
        "options": {}
      },
      "id": "c6096b3d-13b7-444e-8193-8d21428dae52",
      "name": "Supabase GET Tickers",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1020,
        460
      ]
    },
    {
      "parameters": {
        "jsCode": "// ── Formata resultado e salva no cache ───────────────\nconst rows    = $input.all().map(i => i.json);\nconst tickers = rows.map(r => r.ticker).filter(Boolean);\nconst payload = { tickers, count: tickers.length };\n\n// Persiste no Static Data (sobrevive entre execuções)\nconst cached         = $getWorkflowStaticData('global');\ncached.tickers_data  = payload;\ncached.tickers_ts    = Date.now();\n\nconsole.log(`Cache WRITE — ${tickers.length} tickers salvos`);\n\nreturn [{ json: { ...payload, cache_hit: false, cache_age_min: 0 } }];\n"
      },
      "id": "32242e96-ba7f-4de2-b935-768d3e935a54",
      "name": "Salvar Cache",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1260,
        460
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, tickers: $json.tickers, count: $json.count, cache_hit: $json.cache_hit, cache_age_min: $json.cache_age_min }) }}",
        "options": {
          "responseCode": 200
        }
      },
