{
  "name": "MT5.Supabase-GetTickers",
  "nodes": [
    {
      "parameters": {
        "path": "get-tickers",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "45b2d98c-7e5a-4f08-a1a2-e03d1978f81c",
      "name": "Webhook GET Tickers",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        300,
        300
      ],
      "webhookId": "get-tickers"
    },
    {
      "parameters": {
        "jsCode": "// ── Lê cache da Static Data do workflow ──────────────\nconst cached = $getWorkflowStaticData('global');\n\nconst now        = Date.now();\nconst TTL_MS     = 24 * 60 * 60 * 1000; // 24 horas em ms\nconst cacheValid = cached.tickers_data &&\n                   cached.tickers_ts   &&\n                   (now - cached.tickers_ts) < TTL_MS;\n\nif(cacheValid) {\n  const age_min = Math.floor((now - cached.tickers_ts) / 60000);\n  console.log(`Cache HIT — ${cached.tickers_data.count} tickers — idade: ${age_min}min`);\n  return [{ json: { ...cached.tickers_data, cache_hit: true, cache_age_min: age_min } }];\n}\n\nconsole.log('Cache MISS — buscando no Supabase...');\nreturn [{ json: { cache_hit: false } }];\n"
      },
      "id": "d7204210-10c6-4d8f-8f3f-c0bdc2d660c9",
      "name": "Verificar Cache",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        540,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "cache-hit-condition",
              "leftValue": "={{ $json.cache_hit }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "0913618c-d784-4236-8406-f41f9d4dda63",
      "name": "Cache válido?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        780,
        300
      ]
    },
    {
      "parameters": {
        "url": "={{$env.SUPABASE_URL}}/rest/v1/tickers?select=ticker&order=ticker.asc",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_API_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.SUPABASE_ANON_KEY}}"
            },
