    {
      "parameters": {
        "jsCode": "// Normaliza o payload vindo do MT5\nconst body = $input.first().json.body\n\nconst ticker = (body.symbol || '').trim();\nif (!ticker) throw new Error('Campo symbol ausente no payload');\n\nreturn [{\n  json: {\n    ticker,\n    payload : {signal: body.signal, volume_real: body.volume_real, volume_ma: body.volume_ma, volume_ratio: body.volume_ratio }\n  }\n}];\n"
      },
      "id": "d0fbcddc-6579-4fb9-a433-f28fa8b33ec5",
      "name": "Extrai ticker e payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -340,
        260
      ]
    },
    {
      "parameters": {
        "url": "={{$env.SUPABASE_URL}}/rest/v1/indicators",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "ticker",
              "value": "=eq.{{ $json.ticker }}"
            },
            {
              "name": "select",
              "value": "id,ticker,data_mt5"
            },
            {
              "name": "limit",
              "value": "1"
            }
          ]
