              "value": "application/json"
            }
          ]
        },
        "options": {}
      },
      "id": "91e545c5-91fe-4731-aee9-fff6cb0e5420",
      "name": "GET registro atual",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        -100,
        260
      ]
    },
    {
      "parameters": {
        "jsCode": "// Faz merge de data_mt5 preservando as outras chaves do jsonb\nconst getResult = $input.first().json;\n\n// O GET retorna array; pega o primeiro registro\nconst row = Array.isArray(getResult) ? getResult[0] : getResult;\n\nif (!row) throw new Error('Ticker não encontrado na tabela indicators: ' + $('Extrai ticker e payload').item.json.ticker);\n\n// data_mt5 atual (pode ser null)\nconst currentDataMt5 = row.data_mt5 || {};\n\n// Payload do EA (vem do node anterior na chain)\nconst payload = $('Extrai ticker e payload').item.json.payload;\n\n// Merge: mantém tudo que já existe em data_mt5 e substitui/adiciona só volumeMoveAverage\nconst newDataMt5 = {\n  ...currentDataMt5,\n  volumeMoveAverage: payload\n};\n\nreturn [{\n  json: {\n    ticker: $('Extrai ticker e payload').item.json.ticker,\n    data_mt5: newDataMt5\n  }\n}];\n"
      },
